{
  "name": "tcl-tv-cast",
  "version": "0.1.0",
  "description": "Alpha Mac-to-TCL/Android TV screen casting prototype over local Wi-Fi.",
  "private": true,
  "type": "module",
  "main": "apps/mac-desktop/main.js",
  "scripts": {
    "app": "electron apps/mac-desktop/main.js",
    "dev": "node apps/mac-sender/src/server.js",
    "doctor": "node scripts/doctor.js",
    "build:receiver": "node scripts/build-receiver.js",
    "install:adb": "node scripts/install-platform-tools.js",
    "install:android-sdk": "node scripts/install-android-sdk.js",
    "check:desktop": "node --check apps/mac-desktop/main.js",
    "package:mac": "electron-builder --mac --dir",
    "package:mac:zip": "electron-builder --mac zip",
    "package:mac:dmg": "electron-builder --mac dmg",
    "open:mac": "open outputs/desktop/mac-arm64/TCL\\ TV\\ Cast.app",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bonjour-service": "^1.4.1",
    "express": "^5.1.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "socket.io-client": "^4.8.3",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "dev.tclcast.sender",
    "productName": "TCL TV Cast",
    "directories": {
      "output": "outputs/desktop"
    },
    "files": [
      "apps/mac-desktop/**/*",
      "apps/mac-sender/src/**/*",
      "apps/mac-sender/public/**/*",
      "apps/android-tv-receiver/**/*",
      "!apps/android-tv-receiver/app/build/**/*",
      "!apps/android-tv-receiver/.gradle/**/*",
      "!apps/android-tv-receiver/.gradle-wrapper-cache/**/*",
      "!apps/android-tv-receiver/local.properties",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "apps/android-tv-receiver/app/build/outputs/apk/debug/app-debug.apk",
        "to": "receiver/app-debug.apk"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dir"
      ]
    }
  }
}
